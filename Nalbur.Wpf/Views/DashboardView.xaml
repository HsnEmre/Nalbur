<UserControl x:Class="Nalbur.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Özet kartlar -->
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <materialDesign:Card Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Gecikmiş Taksit" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OverdueCount}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Düşük Stok" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LowStockCount}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Yaklaşan Firma Ödemesi" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UpcomingPaymentsCount}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Gecikmiş Firma Ödemesi" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OverduePaymentsCount}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Sol -->
                <materialDesign:Card Grid.Row="0" Grid.Column="0" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Bugün Vadeli Taksitler" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding TodayDueInstallments}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Müşteri" Binding="{Binding InstallmentPlan.Sale.Customer.Name}" Width="*" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat=C2}" Width="100" />
                                <DataGridTextColumn Header="Vade" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Yaklaşan Taksitler" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding UpcomingInstallments}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Müşteri" Binding="{Binding InstallmentPlan.Sale.Customer.Name}" Width="*" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat=C2}" Width="100" />
                                <DataGridTextColumn Header="Vade" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="2" Grid.Column="0" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Düşük Stok Ürünler" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding LowStockProducts}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ürün" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Stok" Binding="{Binding CurrentStock}" Width="80" />
                                <DataGridTextColumn Header="Min." Binding="{Binding MinimumStock}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Sağ -->
                <materialDesign:Card Grid.Row="0" Grid.Column="1" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Gecikmiş Taksitler" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding OverdueInstallments}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Müşteri" Binding="{Binding InstallmentPlan.Sale.Customer.Name}" Width="*" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat=C2}" Width="100" />
                                <DataGridTextColumn Header="Vade" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" Grid.Column="1" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Yaklaşan Firma Ödemeleri" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding UpcomingOutgoingPayments}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Başlık" Binding="{Binding Title}" Width="*" />
                                <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="120" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat=C2}" Width="100" />
                                <DataGridTextColumn Header="Vade" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="2" Grid.Column="1" Margin="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Gecikmiş Firma Ödemeleri" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding OverdueOutgoingPayments}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Başlık" Binding="{Binding Title}" Width="*" />
                                <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="120" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat=C2}" Width="100" />
                                <DataGridTextColumn Header="Vade" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>