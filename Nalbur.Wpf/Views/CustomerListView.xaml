<UserControl x:Class="Nalbur.Wpf.Views.CustomerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Customer List -->
        <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Başlık + Arama -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Müşteri Listesi"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="İsme göre müşteri ara"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignTextBox}" />
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Customers}" 
                          SelectedItem="{Binding SelectedCustomer}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ad"
                                            Binding="{Binding Name}"
                                            Width="100" />

                        <DataGridTextColumn Header="Soyad / Firma"
                                            Binding="{Binding SurnameCompany}"
                                            Width="*" />

                        <DataGridTextColumn Header="Telefon"
                                            Binding="{Binding Phone}"
                                            Width="120" />

                        <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}"
                                            Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Add Form -->
        <materialDesign:Card Grid.Column="1" Padding="16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Yeni Müşteri Ekle" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Text" Value="Müşteriyi Düzenle" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding NewCustomer.Name}"
                         materialDesign:HintAssist.Hint="Ad"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Margin="0,0,0,16" />

                <TextBox Text="{Binding NewCustomer.SurnameCompany}"
                         materialDesign:HintAssist.Hint="Soyad / Firma Adı"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Margin="0,0,0,16" />

                <TextBox Text="{Binding NewCustomer.Phone}"
                         materialDesign:HintAssist.Hint="Telefon"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Margin="0,0,0,16" />

                <TextBox Text="{Binding NewCustomer.Email}"
                         materialDesign:HintAssist.Hint="Email"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Margin="0,0,0,16" />

                <TextBox Text="{Binding NewCustomer.Address}"
                         materialDesign:HintAssist.Hint="Adres"
                         materialDesign:HintAssist.IsFloating="True"
                         AcceptsReturn="True"
                         Height="80"
                         VerticalAlignment="Top"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Margin="0,0,0,16" />

                <Grid ShowGridLines="False" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.ColumnSpan="2"
                            Command="{Binding SaveCustomerCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Content" Value="KAYDET" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Content" Value="GÜNCELLE" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="0"
                            Command="{Binding DeleteCustomerCommand}" 
                            Content="SİL" 
                            Margin="0,0,4,0"
                            BorderBrush="Red"
                            Foreground="Red">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Command="{Binding ClearFormCommand}" 
                            Content="TEMİZLE"
                            Style="{StaticResource MaterialDesignFlatButton}" 
                            Margin="4,0,0,0" />
                                                          
                    
                </Grid>

                <Grid>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--<TextBlock Text="Müşteri Listesi"
               FontSize="18"
               FontWeight="SemiBold"
               VerticalAlignment="Center" />-->

                        <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                            <Button Command="{Binding ExportExcelCommand}"
                Content="EXCEL"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Margin="0,0,8,0" />

                            <Button Command="{Binding ExportWordCommand}"
                Content="WORD"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Margin="0,0,8,0" />

                            <Button Command="{Binding ExportPdfCommand}"
                Content="PDF"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </StackPanel>
                    </Grid>
                </Grid>
                
                
                
            </StackPanel>
            
        </materialDesign:Card>
    </Grid>
</UserControl>