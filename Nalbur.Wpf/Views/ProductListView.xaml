<UserControl x:Class="Nalbur.Wpf.Views.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Product List -->
        <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Başlık + Arama -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Ürün Listesi"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Ürün adına göre ara"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignTextBox}" />
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Products}" 
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="80" />
                        <DataGridTextColumn Header="Barkod" Binding="{Binding Barcode}" Width="100" />
                        <DataGridTextColumn Header="İsim" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="100" />

                        <DataGridTextColumn Header="Stok"
                        Binding="{Binding CurrentStock, StringFormat=N2}"
                        Width="80" />

                        <DataGridTextColumn Header="Birim"
                        Binding="{Binding StockUnit}"
                        Width="90" />

                        <DataGridTextColumn Header="Satış Fiyatı"
                        Binding="{Binding SalePrice, StringFormat=C2}"
                        Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Add/Edit Form -->
        <materialDesign:Card Grid.Column="1" Padding="16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Yeni Ürün Ekle" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Text" Value="Ürünü Düzenle" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox Text="{Binding NewProduct.Code}" materialDesign:HintAssist.Hint="Ürün Kodu" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignTextBox}" Margin="0,0,0,16" />
                <TextBox Text="{Binding NewProduct.Barcode}" materialDesign:HintAssist.Hint="Barkod" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignTextBox}" Margin="0,0,0,16" />
                <TextBox Text="{Binding NewProduct.Name}" materialDesign:HintAssist.Hint="Ürün Adı" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignTextBox}" Margin="0,0,0,16" />
                <TextBox Text="{Binding NewProduct.Category}" materialDesign:HintAssist.Hint="Kategori" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignTextBox}" Margin="0,0,0,16" />
                <TextBox Text="{Binding NewProduct.CostPrice}" materialDesign:HintAssist.Hint="Alış Fiyatı" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignTextBox}" Margin="0,0,0,16" />
                <TextBox Text="{Binding NewProduct.SalePrice}" materialDesign:HintAssist.Hint="Satış Fiyatı" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignTextBox}" Margin="0,0,0,16" />
                <TextBox Text="{Binding NewProduct.CurrentStock}"
         materialDesign:HintAssist.Hint="Mevcut Stok"
         materialDesign:HintAssist.IsFloating="True"
         Style="{StaticResource MaterialDesignTextBox}"
         Margin="0,0,0,16" />

                <ComboBox ItemsSource="{Binding UnitOptions}"
          SelectedItem="{Binding NewProduct.StockUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          materialDesign:HintAssist.Hint="Stok Birimi"
          materialDesign:HintAssist.IsFloating="True"
          Style="{StaticResource MaterialDesignComboBox}"
          Margin="0,0,0,16" />

                <TextBox Text="{Binding NewProduct.MinimumStock}"
         materialDesign:HintAssist.Hint="Min. Stok"
         materialDesign:HintAssist.IsFloating="True"
         Style="{StaticResource MaterialDesignTextBox}"
         Margin="0,0,0,16" />
                <Grid ShowGridLines="False" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.ColumnSpan="2" Command="{Binding SaveProductCommand}" Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Content" Value="KAYDET" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Content" Value="GÜNCELLE" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="0"
                            Command="{Binding DeleteProductCommand}" 
                            Content="SİL" 
                            Margin="0,0,4,0"
                            BorderBrush="Red"
                            Foreground="Red">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Command="{Binding ClearFormCommand}" 
                            Content="TEMİZLE"
                            Style="{StaticResource MaterialDesignFlatButton}" 
                            Margin="4,0,0,0" />                    
                </Grid>
                <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,0,0,12">

                    <Button Command="{Binding ExportExcelCommand}"
            Content="EXCEL"
            Style="{StaticResource MaterialDesignOutlinedButton}"
            Margin="0,0,8,0" />

                    <Button Command="{Binding ExportWordCommand}"
            Content="WORD"
            Style="{StaticResource MaterialDesignOutlinedButton}"
            Margin="0,0,8,0" />

                    <Button Command="{Binding ExportPdfCommand}"
            Content="PDF"
            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>