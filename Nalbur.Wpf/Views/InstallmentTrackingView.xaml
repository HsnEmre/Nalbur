<UserControl x:Class="Nalbur.Wpf.Views.InstallmentTrackingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Taksit Takip Sistemi" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

        <materialDesign:Card Grid.Row="1" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid ItemsSource="{Binding Installments}" 
                          SelectedItem="{Binding SelectedInstallment}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Müşteri" Binding="{Binding InstallmentPlan.Sale.Customer.Name}" Width="*" />
                        <DataGridTextColumn Header="Miktar" Binding="{Binding Amount, StringFormat=C2}" Width="100" />
                        <DataGridTextColumn Header="Vade Tarihi" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="120" />
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Ödeme Tarihi" Binding="{Binding PaymentDate, StringFormat=dd.MM.yyyy}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="1" Command="{Binding PayInstallmentCommand}" 
                        Content="ÖDEME AL" HorizontalAlignment="Right" Margin="0,16,0,0"
                        Style="{StaticResource MaterialDesignRaisedButton}" />
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
