<UserControl x:Class="Nalbur.Wpf.Views.WorkContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header / Filter / List Export -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <DatePicker SelectedDate="{Binding StartDate}"
                                materialDesign:HintAssist.Hint="Başlangıç"
                                Width="150"
                                Margin="0,0,16,0"
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

                    <DatePicker SelectedDate="{Binding EndDate}"
                                materialDesign:HintAssist.Hint="Bitiş"
                                Width="150"
                                Margin="0,0,16,0"
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

                    <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Başlık / müşteri / iş / malzeme ara"
                             materialDesign:HintAssist.IsFloating="True"
                             Width="280"
                             Margin="0,0,16,0"
                             Style="{StaticResource MaterialDesignTextBox}" />

                    <Button Command="{Binding SearchCommand}"
                            Content="ARA"
                            VerticalAlignment="Bottom" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="16,0,0,0">

                    <TextBlock Text="Liste:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,8,0" />

                    <Button Command="{Binding ExportExcelCommand}"
                            Content="EXCEL"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0" />

                    <Button Command="{Binding ExportWordCommand}"
                            Content="WORD"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0" />

                    <Button Command="{Binding ExportPdfCommand}"
                            Content="PDF"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Contract List -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Sözleşme Listesi"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Contracts}"
                              SelectedItem="{Binding SelectedContract}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No"
                                                Binding="{Binding Id}"
                                                Width="50" />

                            <DataGridTextColumn Header="Tarih"
                                                Binding="{Binding ContractDate, StringFormat=dd.MM.yyyy}"
                                                Width="100" />

                            <DataGridTextColumn Header="Başlık"
                                                Binding="{Binding Title}"
                                                Width="*" />

                            <DataGridTextColumn Header="Müşteri"
                                                Binding="{Binding CustomerName}"
                                                Width="140" />

                            <DataGridTextColumn Header="Telefon"
                                                Binding="{Binding CustomerPhone}"
                                                Width="110" />

                            <DataGridTextColumn Header="İş Özeti"
                                                Binding="{Binding WorkDescription}"
                                                Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- Add / Edit Form -->
            <materialDesign:Card Grid.Column="1" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Yeni Sözleşme" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="Sözleşmeyi Düzenle" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <DatePicker SelectedDate="{Binding NewContract.ContractDate}"
                                    materialDesign:HintAssist.Hint="Sözleşme Tarihi"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Margin="0,0,0,16" />

                        <TextBox Text="{Binding NewContract.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Sözleşme Başlığı"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox Text="{Binding NewContract.CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Müşteri / Firma Adı"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox Text="{Binding NewContract.CustomerPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Telefon"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox Text="{Binding NewContract.WorkDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Yapılacak İşler"
                                 materialDesign:HintAssist.IsFloating="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="120"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox Text="{Binding NewContract.Materials, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Kullanılacak Malzemeler"
                                 materialDesign:HintAssist.IsFloating="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="120"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox Text="{Binding NewContract.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Notlar"
                                 materialDesign:HintAssist.IsFloating="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="80"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Margin="0,0,0,16" />

                        <!-- Selected Contract Export -->
                        <Separator Margin="0,4,0,12" />

                        <TextBlock Text="Sözleşme Formatında Çıktı"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">

                            <Button Command="{Binding ExportSelectedContractExcelCommand}"
                                    Content="EXCEL"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,8,0" />

                            <Button Command="{Binding ExportSelectedContractWordCommand}"
                                    Content="WORD"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,8,0" />

                            <Button Command="{Binding ExportSelectedContractPdfCommand}"
                                    Content="PDF"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </StackPanel>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0"
                                    Grid.ColumnSpan="2"
                                    Command="{Binding SaveContractCommand}"
                                    Margin="0,0,0,8">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Content" Value="KAYDET" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Content" Value="GÜNCELLE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Command="{Binding DeleteContractCommand}"
                                    Content="SİL"
                                    Margin="0,0,4,0"
                                    BorderBrush="Red"
                                    Foreground="Red">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Command="{Binding ClearFormCommand}"
                                    Content="TEMİZLE"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Margin="4,0,0,0" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>